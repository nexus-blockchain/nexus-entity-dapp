# Substrate node WebSocket endpoint
NEXT_PUBLIC_WS_ENDPOINT=ws://127.0.0.1:9944

# IPFS API URL for uploads (optional — if not set, auto-selects from Nexus nodes)
# NEXT_PUBLIC_IPFS_API_URL=http://127.0.0.1:5001

# IPFS Gateway URL for reading (optional — if not set, auto-selects from Nexus nodes)
# NEXT_PUBLIC_IPFS_GATEWAY=http://127.0.0.1:8080/ipfs
